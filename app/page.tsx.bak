                <span style={{ fontSize: 'clamp(15px, 1.4vw, 17px)', fontWeight: 600, letterSpacing: '0.12em', color: '#ffffff', marginBottom: '2px', textShadow: '0 1px 8px rgba(0,0,0,0.5)' }}>{item.label}</span>
