            style={{ borderColor: 'rgba(212,168,67,0.3)', background: 'rgba(255,255,255,0.05)', color: 'rgba(212,180,100,0.85)' }}>
            <span className="text-[12px] sm:text-[13px] font-medium tracking-wide select-none">合盘</span>
